{
  "$schema": "https://unpkg.com/syncpack@14/schema.json",
  "semverGroups": [
    {
      "label": "Enforce pinned versions (no ^ or ~)",
      "dependencies": ["**"],
      "dependencyTypes": ["prod", "dev"],
      "packages": ["**"],
      "range": ""
    },
    {
      "label": "Enforce caret ranges for peers",
      "dependencies": ["**"],
      "dependencyTypes": ["peer"],
      "packages": ["**"],
      "range": "^"
    }
  ]
}
